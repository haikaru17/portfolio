---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404: KERNEL_PANIC | Haikal Luthfianino">
    <main class="max-w-4xl mx-auto px-6 min-h-[70vh] flex flex-col items-center justify-center text-center font-code">
        
        <div class="mb-8 p-6 bg-red-500/10 border border-red-500/20 rounded-2xl animate-pulse">
            <svg class="w-16 h-16 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
            </svg>
        </div>

        <h1 class="text-4xl md:text-6xl font-extrabold text-black dark:text-white mb-4">
            404: <span class="text-red-500">SEGMENTATION_FAULT</span>
        </h1>
        
        <div class="bg-neutral-100 dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 p-6 rounded-xl text-left max-w-lg w-full mb-10 shadow-inner">
            <p class="text-neutral-600 dark:text-neutral-400 text-sm leading-relaxed">
                <span class="text-emerald-500">[SYSTEM]</span>: Attempting to access non-existent memory address...<br>
                <span class="text-red-500">[ERROR]</span>: Page not found at this directory.<br>
                <span class="text-neutral-500">[INFO]</span>: User: Haikal Luthfianino Balukia<br>
                <span class="text-neutral-500">[INFO]</span>: Status: Student @ UNSAP Sumedang<br>
                <span class="text-emerald-500">[RECOVERY]</span>: System reboot suggested.
            </p>
        </div>

        <div class="flex flex-col sm:flex-row gap-4">
            <a href="/" class="px-8 py-3 bg-black dark:bg-white text-white dark:text-black font-bold rounded-xl hover:opacity-80 transition-all flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                Return to Home
            </a>
            <a href="mailto:haikalluthfianinobalukia@proton.me" class="px-8 py-3 border border-neutral-200 dark:border-neutral-800 text-neutral-600 dark:text-neutral-400 hover:bg-neutral-100 dark:hover:bg-neutral-800 rounded-xl transition-all">
                Report Issue
            </a>
        </div>
    </main>
</Layout>
