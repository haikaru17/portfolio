---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Haikal Luthfianino | Portfolio">
    <main class="max-w-5xl mx-auto px-6 w-full pt-10 md:pt-20">
        <div class="max-w-2xl mx-auto md:mx-0 space-y-4 flex flex-col items-start text-left">
            
            <div class="inline-flex items-center gap-1.5 px-4 py-2 border border-glass-border-light dark:border-glass-border-dark backdrop-blur-md bg-glass-light/70 dark:bg-glass-dark/70 text-neutral-600 dark:text-neutral-300 text-sm font-code rounded-full shadow-sm antialiased">
                <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 shadow-lg shadow-emerald-500/30 animate-pulse"></span>
                <span>whoami</span>
                <span class="text-emerald-500 font-bold ml-1">></span>
                <span class="text-emerald-500">root</span>@haikal: ~
                <span class="animate-blink font-bold text-black dark:text-white ml-0.5">_</span>
            </div>

            <h1 class="text-5xl md:text-7xl font-extrabold text-black dark:text-white tracking-tight mb-4 leading-tight antialiased">
                Halo, saya <span class="text-black dark:text-white underline decoration-4 decoration-neutral-300 dark:decoration-neutral-600 underline-offset-8">Haikal.</span>
            </h1>

            <h2 class="text-xl md:text-3xl text-neutral-600 dark:text-neutral-400 font-medium mb-6 antialiased">
                Informatics Student & System Enthusiast.
               
            </h2>

            <p class="text-base md:text-lg mb-10 leading-relaxed text-neutral-500 dark:text-neutral-500 antialiased">
                Saya mengkhususkan diri pada pengembangan perangkat lunak tingkat rendah (low-level systems), modifikasi Android (AOSP), dan perbaikan perangkat keras tingkat komponen.
            </p>

            <div class="flex gap-4 items-center justify-start font-code text-sm pt-2">
                
                <a href="/experience" class="px-6 py-3 rounded-xl backdrop-blur-2xl saturate-150 border text-black dark:text-white font-bold text-sm bg-white/20 dark:bg-white/10 border-white/40 dark:border-white/10 shadow-[0_4px_16px_0_rgba(0,0,0,0.05)] dark:shadow-[0_4px_16px_0_rgba(255,255,255,0.02)] transition-all duration-300 ease-out hover:bg-white/30 dark:hover:bg-white/20 active:scale-[0.97] hover:-translate-y-0.5 active:bg-neutral-200 dark:active:bg-neutral-800 transition-colors">
                    Lihat Project
                </a>
            </div>
        </div>
    </main>
</Layout>
