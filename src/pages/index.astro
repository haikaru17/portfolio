---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Haikal Luthfianino | Portfolio">
    <main class="max-w-5xl mx-auto px-6 w-full">
        <div class="flex flex-col-reverse md:flex-row items-center md:items-start gap-12 pt-10">
            
            <div class="flex-1 text-center md:text-left">
                <div class="inline-block px-4 py-2 mb-6 border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-[#0a0a0a] text-neutral-600 dark:text-neutral-300 text-sm font-code rounded-xl shadow-sm dark:shadow-md">
                    <span class="text-emerald-500 font-bold">></span> whoami
                    <br class="hidden sm:block"> 
                    <span class="text-emerald-500">root</span>@haikal: ~<span class="animate-blink font-bold text-black dark:text-white ml-1">_</span>
                </div>

                <h1 class="text-5xl md:text-7xl font-extrabold text-black dark:text-white tracking-tight mb-4 leading-tight">
                    Halo, saya <span class="text-black dark:text-white underline decoration-4 decoration-neutral-300 dark:decoration-neutral-600 underline-offset-8">Haikal.</span>
                </h1>
                
                <h2 class="text-xl md:text-3xl text-neutral-600 dark:text-neutral-400 font-medium mb-6">
                    Informatics Student & System Enthusiast.
                </h2>

                <p class="text-base md:text-lg max-w-2xl mx-auto md:mx-0 mb-10 leading-relaxed text-neutral-500 dark:text-neutral-500">
                    Saya mengkhususkan diri pada pengembangan perangkat lunak tingkat rendah (low-level systems), modifikasi Android (AOSP), dan perbaikan perangkat keras tingkat komponen.
                </p>

                <div class="flex gap-4 justify-center md:justify-start font-code text-sm">
                    <a href="/experience" class="px-6 py-3 rounded-xl bg-black dark:bg-white text-white dark:text-black font-bold transition-all shadow-lg hover:opacity-80">
                        Lihat Project
                    </a>
                </div>
            </div>

            <div class="flex-shrink-0 relative group">
                <div class="absolute inset-0 rounded-full bg-neutral-300 dark:bg-neutral-800 blur-2xl opacity-40 group-hover:opacity-60 transition-opacity"></div>
                <div class="w-48 h-48 md:w-64 md:h-64 rounded-full overflow-hidden border-2 border-neutral-200 dark:border-neutral-800 bg-white dark:bg-[#0a0a0a] relative z-10 p-2 shadow-xl group-hover:border-neutral-400 dark:group-hover:border-neutral-700 transition-colors">
                    <img src="https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=600&auto=format&fit=crop" alt="Haikal Luthfianino" class="w-full h-full object-cover rounded-full grayscale hover:grayscale-0 transition-all duration-500"/>
                </div>
            </div>

        </div>
    </main>
</Layout>
