---
import '../styles/global.css';
import FloatingNav from '../components/FloatingNav.astro';
import { ClientRouter } from 'astro:transitions';

const { title = "Haikal Luthfianino | Portfolio" } = Astro.props;
---

<!doctype html>
<html lang="id" id="html-root">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <title>{title}</title>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
        
        <ClientRouter />

        <script is:inline>
            function applyTheme() {
                const theme = (() => {
                    if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
                        return localStorage.getItem('theme');
                    }
                    if (window.matchMedia('(prefers-color-scheme: dark)').matches) return 'dark';
                    return 'light'; 
                })();
                
                if (theme === 'light') {
                    document.documentElement.classList.remove('dark');
                } else {
                    document.documentElement.classList.add('dark');
                }
                window.localStorage.setItem('theme', theme);
            }

            applyTheme();
            document.addEventListener('astro:after-swap', applyTheme);
        </script>
    </head>

    <body class="bg-neutral-50 dark:bg-[#050505] text-neutral-800 dark:text-neutral-300 min-h-screen relative selection:bg-emerald-500 selection:text-white pb-32 transition-colors duration-500 antialiased overflow-x-hidden">
        
        <div class="fixed inset-0 z-0 pointer-events-none overflow-hidden">
            <div class="absolute -top-[10%] -left-[10%] w-[50%] h-[50%] rounded-full bg-emerald-500/10 dark:bg-emerald-900/20 blur-[120px]"></div>
            <div class="absolute bottom-[-10%] -right-[10%] w-[50%] h-[50%] rounded-full bg-neutral-300/40 dark:bg-neutral-800/40 blur-[120px]"></div>
        </div>
        
        <div id="page-transition-skeleton" class="fixed inset-0 z-40 hidden bg-white/70 dark:bg-black/70 backdrop-blur-xl transition-opacity duration-300 flex-col items-center justify-start pt-32 px-6">
            <div class="max-w-4xl w-full flex flex-col gap-6 opacity-60">
                <div class="w-1/3 h-12 rounded-xl bg-neutral-300 dark:bg-neutral-800 animate-skeleton-pulse"></div>
                <div class="space-y-4 w-full">
                    <div class="w-full h-4 rounded-full bg-neutral-300 dark:bg-neutral-800 animate-skeleton-pulse"></div>
                    <div class="w-11/12 h-4 rounded-full bg-neutral-300 dark:bg-neutral-800 animate-skeleton-pulse" style="animation-delay: 0.1s;"></div>
                    <div class="w-4/5 h-4 rounded-full bg-neutral-300 dark:bg-neutral-800 animate-skeleton-pulse" style="animation-delay: 0.2s;"></div>
                </div>
                <div class="w-full h-32 rounded-2xl bg-neutral-300 dark:bg-neutral-800 animate-skeleton-pulse mt-4" style="animation-delay: 0.3s;"></div>
            </div>
        </div>

        <div id="main-content" class="relative z-10 pt-20 animate-fade-in">
            <slot />
        </div>
        
        <FloatingNav />

        <script>
            function initSkeleton() {
                const skeleton = document.getElementById('page-transition-skeleton');
                const content = document.getElementById('main-content');

                if (!skeleton || !content) return;

                document.addEventListener('astro:before-preparation', () => {
                    skeleton.classList.remove('hidden');
                    skeleton.classList.add('flex');
                    content.style.opacity = '0';
                });

                document.addEventListener('astro:page-load', () => {
                    skeleton.classList.add('hidden');
                    skeleton.classList.remove('flex');
                    content.style.opacity = '1';
                });
            }

            initSkeleton();
        </script>
    </body>
</html>
<style is:global>
    body { 
        font-family: 'Inter', sans-serif; 
    }
    .font-code { 
        font-family: 'JetBrains Mono', monospace; 
    }
</style>
